# 是否启用大模型
LLM_ENABLED=true

# 模型名称
LLM_MODEL=qwen2.5:3b

# 大模型接口类型：ollama 或 openai
LLM_API_TYPE=ollama

# 接口地址：
# - Ollama 例子：http://127.0.0.1:11434
# - OpenAI / LM Studio 例子：http://127.0.0.1:1234/v1
# - 远端 OpenAI 兼容网关例子：http://your-host:11435/v1
LLM_API_URL=http://127.0.0.1:11434

# OpenAI 兼容接口的 API Key；LM Studio / 本地网关通常可留空
LLM_API_KEY=

# 请求超时（秒）
LLM_TIMEOUT=30

# NPC 历史消息轮数上限
LLM_MAX_HISTORY=12

# 服务监听地址与端口
MUD_BIND_HOST=0.0.0.0
MUD_BIND_PORT=7777

# 出生点房间 ID
BORN_POINT=StationHall

# 客户端编码：utf-8 或 gbk
CLIENT_ENCODING=utf-8
